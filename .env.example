# API Configuration for Real Device Testing
# Set this to your development machine's IP address for testing on real devices
# Leave empty for simulator/emulator (uses localhost)
# Example: EXPO_PUBLIC_LOCAL_HOST_IP=192.168.1.100
EXPO_PUBLIC_LOCAL_HOST_IP=

# Google Sign-In Configuration
# Get your Web Client ID from: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Get your iOS Client ID from: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
